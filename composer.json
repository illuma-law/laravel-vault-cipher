{
    "name": "illuma-law/laravel-vault-cipher",
    "description": "Tenant-aware streaming encryption for Laravel.",
    "type": "library",
    "license": "MIT",
    "authors": [
        {
            "name": "Menes",
            "email": "menes@illuma.law"
        }
    ],
    "require": {
        "php": "^8.5",
        "illuminate/contracts": "^11.0|^12.0|^13.0",
        "illuminate/database": "^11.0|^12.0|^13.0",
        "illuminate/support": "^11.0|^12.0|^13.0",
        "spatie/laravel-package-tools": "^1.16",
        "ercsctt/laravel-file-encryption": "^1.1"
    },
    "require-dev": {
        "laravel/pint": "^1.14",
        "nunomaduro/collision": "^8.1|^9.0",
        "larastan/larastan": "^3.0",
        "orchestra/testbench": "^9.0|^10.0",
        "pestphp/pest": "^4.0",
        "pestphp/pest-plugin-arch": "^4.0",
        "pestphp/pest-plugin-laravel": "^4.0",
        "phpstan/extension-installer": "^1.3",
        "phpstan/phpstan-deprecation-rules": "^2.0",
        "phpstan/phpstan-phpunit": "^2.0",
        "spatie/laravel-ray": "^1.35"
    },
    "autoload": {
        "psr-4": {
            "IllumaLaw\\VaultCipher\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "IllumaLaw\\VaultCipher\\Tests\\": "tests/"
        }
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true,
            "phpstan/extension-installer": true
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "IllumaLaw\\VaultCipher\\VaultCipherServiceProvider"
            ],
            "aliases": {
                "TenantEncryption": "IllumaLaw\\VaultCipher\\Facades\\TenantEncryptionManager"
            }
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
